# Runtime
NODE_ENV=development
PORT=5000
REQUEST_LOGGING=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Auth
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=

# Rate limits
RATE_LIMIT_API_MAX=2000
RATE_LIMIT_AUTH_MAX=200
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_PUBLIC_MAX=3000
RATE_LIMIT_ADMIN_MAX=1000

# Cache
CACHE_ENABLED=true
CACHE_MAX_ITEMS=500
CACHE_TTL_MS=60000
CACHE_LISTINGS_TTL_MS=30000
CACHE_CMS_TTL_MS=300000
CACHE_ACCEPTED_PARTNERS_TTL_MS=60000

# Mail (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=NestArrival <no-reply@nestarrival.ca>
ALLOW_CONSOLE_OTP=false

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_KEY_FILE=credentials.json
GOOGLE_SHEETS_KEY_JSON=

# Firebase / FCM
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AWS shared
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# AWS SQS notifications
NOTIFICATION_QUEUE_URL=
AWS_SQS_QUEUE_URL=

# AWS S3 private uploads
AWS_S3_BUCKET=
S3_BUCKET=
AWS_S3_ENDPOINT=
S3_ENDPOINT=
AWS_S3_PREFIX=verification
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_SERVER_SIDE_ENCRYPTION=AES256
