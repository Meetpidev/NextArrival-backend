datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum Role {
  ADMIN
  TENANT
  OWNER
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InquiryStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED

  @@map("InterestRequestStatus")
}

enum InquiryAuditAction {
  CREATED
  ACCEPTED
  DECLINED
  DELETED_FROM_HISTORY
}
enum ChatMessageType {
  TEXT
  INTEREST_REQUEST
}

enum NotificationType {
  INTEREST_REQUEST
  INQUIRY_CREATED
  CHAT_MESSAGE
  OWNER_RESPONSE
  INQUIRY_ACCEPTED
  INQUIRY_REJECTED
  CONTACT_US_SUBMITTED
  PARTNER_REQUEST_SUBMITTED
  SYSTEM
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  passwordHash       String?
  googleId           String?            @unique
  role               Role
  fullName           String?
  isVerified         Boolean            @default(false)
  isBanned           Boolean            @default(false)
  banReason          String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  otp                String?
  otpExpiry          DateTime?
  otpAttempts        Int                @default(0)
  otpLastSentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relocation/Tenant Fields
  currentCountry         String?
  destinationCountry     String? @default("Canada")
  currentStatus          String?
  visaStatus             String?
  visaType               String?
  plannedMoveDate        String?
  purposeOfRelocation    String?
  expectedRentalDuration String?
  residencyStatus        String?

  // Urgent Match Premium Option
  isUrgentMatch          Boolean   @default(false)
  urgentMatchRequestedAt DateTime?

  // Relations
  verificationRequest VerificationRequest?
  listings            Listing[]            @relation("OwnerListings")
  savedListings       SavedListing[]
  subscriptions       Subscription[]
  tenantApproaches    Approach[]           @relation("TenantApproaches")
  ownerApproaches     Approach[]           @relation("OwnerApproaches")
  tenantInquiries    Inquiry[]           @relation("TenantInquiries")
  ownerInquiries     Inquiry[]           @relation("OwnerInquiries")
  notifications       Notification[]
  deviceTokens        DeviceToken[]

  // Chat Relations
  chatRoomsAsTenant ChatRoom[]    @relation("TenantRooms")
  chatRoomsAsOwner  ChatRoom[]    @relation("OwnerRooms")
  sentMessages      ChatMessage[] @relation("SentMessages")

  refundRequests RefundRequest[]

  @@index([role, createdAt])
  @@index([verificationStatus])
  @@index([isBanned])
}

model PendingUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  fullName      String
  role          Role
  otp           String
  otpExpiry     DateTime
  otpAttempts   Int       @default(0)
  otpLastSentAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([otpExpiry])
  @@map("pending_users")
}

model VerificationRequest {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  residencyStatus      String
  documentUrls         String[]
  documentTypes        String[]
  declarationsAccepted Boolean  @default(false)
  adminNotes           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([createdAt])
}

model Listing {
  id               String        @id @default(uuid())
  ownerId          String
  owner            User          @relation("OwnerListings", fields: [ownerId], references: [id], onDelete: Cascade)
  title            String
  description      String
  rent             Float
  location         String
  city             String?
  photos           String[]
  bedrooms         Int
  bathrooms        Int
  availabilityDate DateTime
  status           ListingStatus @default(DRAFT)
  adminFeedback    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  savedBy    SavedListing[]
  approaches Approach[]
  chatRooms  ChatRoom[]
  inquiries  Inquiry[]

  @@index([status, createdAt, id])
  @@index([ownerId, status, createdAt, id])
  @@index([city])
  @@index([status, rent, createdAt, id])
  @@index([status, bedrooms, bathrooms, createdAt, id])
}

model SavedListing {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([userId, createdAt])
}

model Subscription {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId            String // e.g. plan_14_days_sub, plan_30_days_one_time, etc.
  name              String
  price             Float
  durationDays      Int
  isSubscription    Boolean  @default(false)
  approachesAllowed Int // Max approaches, e.g. 5, 15, 30, -1 for unlimited
  approachesUsed    Int      @default(0)
  startDate         DateTime @default(now())
  endDate           DateTime
  isActive          Boolean  @default(false)
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())

  refundRequests RefundRequest[]

  @@index([userId, status, createdAt])
  @@index([userId, isActive, endDate])
  @@index([status, createdAt])
}

model Approach {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    User     @relation("TenantApproaches", fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User     @relation("OwnerApproaches", fields: [ownerId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([tenantId, listingId])
  @@index([ownerId])
  @@index([listingId])
  @@index([createdAt])
}

model Inquiry {
  id               String                @id @default(uuid())
  tenantId         String
  tenant           User                  @relation("TenantInquiries", fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId          String
  owner            User                  @relation("OwnerInquiries", fields: [ownerId], references: [id], onDelete: Cascade)
  propertyId       String
  property         Listing               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantMessage    String
  status           InquiryStatus         @default(PENDING)
  ownerMessage     String?
  respondedAt      DateTime?
  tenantDeletedAt  DateTime?
  ownerDeletedAt   DateTime?
  profileSnapshot  Json
  propertySnapshot Json
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  auditLogs        InquiryAuditLog[]

  @@index([tenantId])
  @@index([ownerId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

model InquiryAuditLog {
  id        String             @id @default(uuid())
  inquiryId String
  inquiry   Inquiry            @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  actorId   String?
  actorRole String?
  action    InquiryAuditAction
  metadata  Json?
  createdAt DateTime           @default(now())

  @@index([inquiryId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("inquiry_audit_logs")
}
model Notification {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        NotificationType
  relatedId   String?
  relatedType String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([relatedId])
  @@index([relatedType])
  @@index([userId, isRead, createdAt])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([userId, isActive])
}

model ChatRoom {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    User          @relation("TenantRooms", fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User          @relation("OwnerRooms", fields: [ownerId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  messages  ChatMessage[]

  @@unique([tenantId, ownerId, listingId])
  @@index([tenantId, createdAt])
  @@index([ownerId, createdAt])
  @@index([listingId])
}

model ChatMessage {
  id          String          @id @default(uuid())
  roomId      String
  room        ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User            @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  messageType ChatMessageType @default(TEXT)
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([roomId, createdAt])
  @@index([senderId])
  @@index([messageType])
}

model RefundRequest {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  status         RefundStatus @default(PENDING)
  reason         String?
  adminNotes     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId, createdAt])
  @@index([subscriptionId])
  @@index([status, createdAt])
}

model CmsPage {
  id        String   @id
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model ContactUs {
  id              String   @id @default(uuid())
  whoAreYou       String
  fullName        String
  email           String
  phone           String?
  destinationCity String?
  visaStatus      String?
  subject         String
  messageDetail   String
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model PartnerInquiry {
  id               String   @id @default(uuid())
  partnershipType  String
  organizationName String
  fullName         String
  email            String
  phone            String?
  country          String
  cityRegion       String?
  partnershipGoal  String
  tellUsMore       String
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

